{
  "name": "@flowmatrix-ai/brand",
  "version": "0.2.1",
  "description": "Flowmatrix brand system",
  "type": "module",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css": "./dist/index.css"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc && node src/css/build-css-vars.js",
    "test": "vitest run",
    "format": "prettier --write \"src/**/*.{ts,js,css}\""
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
